        {
          "name": "设为默认地址",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/user/address/{{addressId}}/default", "host": ["{{baseUrl}}"], "path": ["user", "address", "{{addressId}}", "default"] }
