            "body": { "mode": "raw", "raw": "{\n  \"receiver\": \"张三\",\n  \"phone\": \"13800138000\",\n  \"province\": \"广东省\",\n  \"city\": \"广州市\",\n  \"district\": \"番禺区\",\n  \"detail\": \"大学城某某路100号\"\n}" },
            "url": { "raw": "{{baseUrl}}/user/address", "host": ["{{baseUrl}}"], "path": ["user", "address"] }
          }
        },
        {
          "name": "更新地址",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"receiver\": \"李四\",\n  \"phone\": \"13900139000\",\n  \"detail\": \"大学城某某路200号\"\n}" },
            "url": { "raw": "{{baseUrl}}/user/address/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["user", "address", "{{addressId}}"] }
          }
