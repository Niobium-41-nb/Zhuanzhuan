          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/user/address/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["user", "address", "{{addressId}}"] }
          }
        }
      ]
