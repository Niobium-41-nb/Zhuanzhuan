{
  "info": {
    "name": "转转 - 校园二手交易平台 API",
    "description": "转转后端接口完整测试集合\n\n## 使用说明\n1. 先运行 `POST /api/v1/user/register` 注册用户\n2. 再运行 `POST /api/v1/user/login` 获取 token\n3. 在集合变量 `accessToken` 中会自动保存 token\n4. 后续需要认证的接口会自动携带 token\n\n## 环境变量\n- `{{baseUrl}}` = http://localhost:8080/api/v1\n- `{{accessToken}}` = 登录后自动设置\n- `{{refreshToken}}` = 用于刷新 token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId", "value": "1", "type": "string" },
    { "key": "productId", "value": "1", "type": "string" },
    { "key": "orderId", "value": "1", "type": "string" },
    { "key": "addressId", "value": "1", "type": "string" },
    { "key": "cartId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "🏠 首页",
      "item": [
        {
          "name": "首页推荐",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200))"], "type": "text/javascript" } }],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/index/recommend", "host": ["{{baseUrl}}"], "path": ["index", "recommend"] } }
        },
        {
          "name": "首页统计",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200))"], "type": "text/javascript" } }],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/index/statistics", "host": ["{{baseUrl}}"], "path": ["index", "statistics"] } }
        },
        {
          "name": "公告列表",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/announcement/list", "host": ["{{baseUrl}}"], "path": ["announcement", "list"] } }
        }
      ]
    },
    {
      "name": "👤 用户认证",
      "item": [
        {
          "name": "发送邮箱验证码",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"target\": \"test@example.com\",\n  \"type\": \"register\"\n}" },
            "url": { "raw": "{{baseUrl}}/user/code", "host": ["{{baseUrl}}"], "path": ["user", "code"] }
          }
        },
        {
          "name": "用户注册",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('注册成功', () => {",
                "  const res = pm.response.json();",
                "  pm.expect(res.code).to.eql(200);",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123456\",\n  \"code\": \"123456\"\n}" },
            "url": { "raw": "{{baseUrl}}/user/register", "host": ["{{baseUrl}}"], "path": ["user", "register"] }
          }
        },
        {
          "name": "用户登录",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.code === 200 && res.data) {",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                "  pm.collectionVariables.set('userId', String(res.data.user.userId));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"account\": \"testuser\",\n  \"password\": \"Test123456\"\n}" },
            "url": { "raw": "{{baseUrl}}/user/login", "host": ["{{baseUrl}}"], "path": ["user", "login"] }
          }
        },
        {
          "name": "刷新 Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/user/refresh", "host": ["{{baseUrl}}"], "path": ["user", "refresh"] }
          }
        },
        {
          "name": "重置密码",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"target\": \"test@example.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"NewPass789\"\n}" },
            "url": { "raw": "{{baseUrl}}/user/password/reset", "host": ["{{baseUrl}}"], "path": ["user", "password", "reset"] }
          }
        },
        {
          "name": "退出登录",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/user/logout", "host": ["{{baseUrl}}"], "path": ["user", "logout"] }
          }
        }
      ]
    },
