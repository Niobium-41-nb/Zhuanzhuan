@startuml
!theme plain
skinparam usecase {
  BorderColor #333
  ArrowColor #444
  ActorBorderColor #111
  FontColor #000
}
skinparam rectangle {
  BorderColor #888
  BorderStyle dashed
  BorderThickness 1.5
  FontColor #000
  FontSize 14
  FontStyle bold
}

left to right direction
title 系统顶层用例图

actor "游客" as Visitor
actor "普通用户" as User
actor "管理员" as Admin

rectangle "转转二手交易平台" {

  usecase "浏览商品" as UC1
  usecase "用户注册" as UC2
  usecase "发送消息" as UC3
  usecase "登录系统" as UC4
  usecase "管理地址" as UC5
  usecase "发布商品" as UC6
  usecase "个人信息管理" as UC7
  usecase "编辑商品" as UC8
  usecase "收藏商品" as UC9
  usecase "加入购物车" as UC10
  usecase "下单购买" as UC11
  usecase "确认收货" as UC12
  usecase "评价商品" as UC13
  usecase "商品审核" as UC14
  usecase "用户管理" as UC15
  usecase "订单管理" as UC16
  usecase "数据统计" as UC17
  usecase "公告管理" as UC18

  ' === 关联关系（Actor → UseCase） ===
  Visitor --> UC1
  Visitor --> UC2

  User --> UC3
  User --> UC4
  User --> UC5
  User --> UC6
  User --> UC7
  User --> UC8
  User --> UC9
  User --> UC10
  User --> UC11
  User --> UC12
  User --> UC13

  Admin --> UC14
  Admin --> UC15
  Admin --> UC16
  Admin --> UC17
  Admin --> UC18

  ' === 包含与扩展关系 ===
  UC11 ..> UC5 : <<include>>
  UC11 ..> UC10 : <<include>>
  UC12 ..> UC11 : <<extend>>
  UC13 ..> UC12 : <<extend>>
  UC9 ..> UC1 : <<extend>>
  UC3 ..> UC1 : <<extend>>
  UC8 ..> UC6 : <<extend>>

}
@enduml
