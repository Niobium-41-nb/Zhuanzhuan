# ============================================================
# 校园二手物品交易平台 - 环境变量配置示例
# ============================================================
# 将此文件复制为 .env 并根据实际环境修改配置
# cp .env.example .env
# ============================================================

# ============================================================
# 邮件服务配置（后端 application-dev.yml / application-prod.yml）
# ============================================================

# 邮件 SMTP 服务器地址
MAIL_SERVER=smtp.example.com

# 邮件 SMTP 服务器端口
MAIL_PORT=465

# 邮箱账号
MAIL_USERNAME=your-email@example.com

# 邮箱密码 / 授权码
MAIL_PASSWORD=your-email-password

# 是否启用 SSL（true / false）
MAIL_USE_SSL=true

# 是否启用 TLS（true / false）
MAIL_USE_TLS=false


# ============================================================
# JWT 配置（docker-compose.yml 中已设默认值，可按需覆盖）
# ============================================================

# JWT 签名密钥（生产环境请使用强随机字符串）
JWT_SECRET=ZhuanZhuanSecretKey2024ForJWTTokenGenerationAndValidation

# Access Token 过期时间（毫秒，默认 2 小时）
JWT_ACCESS_TOKEN_EXPIRATION=7200000

# Refresh Token 过期时间（毫秒，默认 7 天）
JWT_REFRESH_TOKEN_EXPIRATION=604800000


# ============================================================
# MySQL 数据库配置（docker-compose.yml 中已设默认值）
# ============================================================

MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=zhuanzhuan
MYSQL_USER=zhuanzhuan
MYSQL_PASSWORD=zhuanzhuan123


# ============================================================
# Redis 配置（docker-compose.yml 中已设默认值）
# ============================================================

REDIS_PASSWORD=redis123


# ============================================================
# 项目开发端口配置
# ============================================================

# 后端 SpringBoot 服务端口（application.yml）
BACKEND_PORT=8080

# 前端 Vite 开发服务器端口（vite.config.ts）
FRONTEND_PORT=5173

# Docker 部署时前端 Nginx 宿主机映射端口（docker-compose.yml）
NGINX_PORT=3000


# ============================================================
# 前端（Vite）环境变量
# ============================================================

# API 基础路径（如不使用代理，可改为后端实际地址）
# VITE_API_BASE=http://localhost:8080/api/v1
